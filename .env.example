# MongoDB
MONGO_URI=

# Server (Railway sets PORT automatically)
PORT=5000

# JWT
JWT_SECRET=

# Email (Resend API — required for OTP, password reset, SOS alerts)
RESEND_API_KEY=
# Verified sender (defaults: SentryAid <otp@product.example.com>)
# RESEND_FROM=SentryAid <otp@product.example.com>
# Or set name and email separately:
# RESEND_FROM_NAME=SentryAid
# RESEND_FROM_EMAIL=otp@product.example.com

# Firebase push notifications (optional path to service account JSON)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# Admin login (optional)
ADMIN_EMAIL=admin@sentryaid.com
