# MongoDB
MONGO_URI=

# Server (Railway sets PORT automatically)
PORT=5000

# JWT
JWT_SECRET=

# Email (Resend API — required for OTP, password reset, SOS alerts)
RESEND_API_KEY=
# Verified domain: product.pookiedhk.com (defaults: SentryAid <otp@product.pookiedhk.com>)
# RESEND_FROM=SentryAid <otp@product.pookiedhk.com>
# Or set name and email separately:
# RESEND_FROM_NAME=SentryAid
# RESEND_FROM_EMAIL=otp@product.pookiedhk.com

# Firebase push notifications (Railway: paste full service account JSON as one line)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n",...}

# Admin login (optional)
ADMIN_EMAIL=admin@sentryaid.com
